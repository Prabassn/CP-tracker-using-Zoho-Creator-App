		workflow
		{
		form
		{
			Auto_Email_Verification as "Auto Email Verification"
			{
				type =  form
				form = contest_logs

				record event = on add

				on success
				{
					actions 
					{
						sendmail
						(
							from : "zoho.adminuserid"
							to : "zoho.loginuserid"
							subject : "Record Added"
							message : "<div>${zoho.loginuserid} has added a record in form Contest Logs<br></div>"
						)
					}
				}

			}
		}





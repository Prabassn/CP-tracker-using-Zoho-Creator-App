	 			row = 1
	 			column = 1   
				width = medium
			)
			profile_visibility
			(
				type = radiobuttons
				displayname = "Profile Visibility"
				values = {"Private","Public"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit

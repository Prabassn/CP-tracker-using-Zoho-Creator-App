			"Developer"
			{
				name = "Developer"
				type = Developer
				permissions = {Chat:false, Predefined:true, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Developer Profile\n"
			}
			"Data Analyst"
			{
				name = "Data Analyst"
				type = Users_Permissions
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Generate performance reports and trend analyses for users \n"
				ModulePermissions
				{
					streaks
					{
						enabled= Viewall 
						allFieldsVisible= true 
						ReportPermissions
						{
							streaks_by_reset_reason={"View"}
							streaks_Report={"View"}
						}
					}
